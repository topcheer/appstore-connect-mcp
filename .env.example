# App Store Connect API credentials
# Get these from https://appstoreconnect.apple.com/access/api
APP_STORE_CONNECT_ISSUER_ID=your-issuer-id-here
APP_STORE_CONNECT_KEY_ID=your-key-id-here

# Private key: either inline PEM content OR a file path
# Option A: inline (paste the full .p8 content including BEGIN/END lines)
APP_STORE_CONNECT_PRIVATE_KEY=

# Option B: file path (mount in Docker)
# APP_STORE_CONNECT_P8_FILE=/run/secrets/AuthKey_XXXXXX.p8

# Optional settings
MCP_VERBOSE=0
